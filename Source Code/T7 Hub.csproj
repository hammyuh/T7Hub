<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>T7_Hub</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>bo3.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Resources\bo3.ico" />
    <None Remove="Resources\bo3.png" />
    <None Remove="Resources\ezz.png" />
    <None Remove="Resources\splash.png" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="bo3.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NETCore" Version="5.0.2" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\bo3.ico" />
    <Resource Include="Resources\bo3.png" />
    <Resource Include="Resources\ezz.png" />
    <Resource Include="Resources\splash.png" />
  </ItemGroup>

</Project>
