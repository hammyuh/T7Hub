<Page x:Class="T7_Hub.Setup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Setup">

    <Grid Margin="30">

        <Border
            Width="550"
            Padding="35"
            CornerRadius="15"
            Background="#AA1C1C1C"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel>

                <TextBlock
                    Text="Welcome to T7 Hub"
                    Foreground="White"
                    FontSize="32"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"/>


                <TextBlock
                    Text="Before continuing, place your desired clients and T7 Patch .conf file (if applicable) inside their matching T7 Hub Standby directories, then remove any previously installed clients or modified files from your BO3 folder. The stock and old BO3 executables can be found at the top of the GitHub README under Requirements, with the old executable only being required for Ezz BOIII. T7 Hub will handle all file switching automatically once setup is complete."
                    Foreground="White"
                    FontSize="15"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    Margin="0,20,0,5"
                    FontWeight="Bold"/>


                <TextBlock
                    Text="Black Ops III Installation:"
                    Foreground="White"
                    FontSize="18"
                    FontWeight="Bold"
                    Margin="0,20,0,10"/>


                <StackPanel Orientation="Horizontal">

                    <TextBox
                        x:Name="BO3PathTB"
                        Width="260"
                        Height="35"
                        VerticalContentAlignment="Center"/>


                    <Button
                        x:Name="BrowseButton"
                        Width="90"
                        Height="35"
                        Margin="10,0,0,0"
                        Content="Browse"
                        Click="BrowseButton_Click"/>


                    <Button
                        x:Name="LocateButton"
                        Width="110"
                        Height="35"
                        Margin="10,0,0,0"
                        Content="Auto Locate"
                        Click="LocateButton_Click"/>

                </StackPanel>


                <TextBlock
                    Text="Client List:"
                    Foreground="White"
                    FontSize="18"
                    FontWeight="Bold"
                    Margin="0,20,0,10"/>


                <Border
                    Background="#222222"
                    CornerRadius="8"
                    Padding="10">

                    <UniformGrid
                        x:Name="ClientList"
                        Columns="3"
                        Rows="3"/>

                </Border>


                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,25,0,0">


                    <Button
                        x:Name="OpenFolderButton"
                        Width="180"
                        Height="45"
                        Margin="5"
                        Content="Open Client Folder"
                        Click="OpenFolderButton_Click"/>


                    <Button
                        x:Name="ContinueButton"
                        Width="180"
                        Height="45"
                        Margin="5"
                        Content="Continue"
                        Click="ContinueButton_Click"/>


                </StackPanel>


            </StackPanel>

        </Border>

    </Grid>

</Page>